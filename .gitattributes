# Enforce LF line endings for all text files
* text=auto eol=lf

# Ensure shell scripts always use LF (critical for bash execution)
*.sh text eol=lf
.husky/* text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
